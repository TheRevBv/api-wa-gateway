META_PROVIDER_CONNECTION_ID=meta_demo_connection
META_PROVIDER_DISPLAY_NAME=Local Meta Cloud API
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
META_API_VERSION=v22.0
META_BASE_URL=https://graph.facebook.com
META_ACTIVATE=true
