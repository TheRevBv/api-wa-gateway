{
  "name": "api-wa-gateway",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "WhatsApp API gateway modular monolith with Fastify, Drizzle and PostgreSQL.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "provider:sync:meta": "tsx scripts/sync-meta-provider.ts"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.19",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
